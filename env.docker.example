# Copie este arquivo para .env.docker na raiz do projeto e ajuste os valores
# Variáveis obrigatórias para rodar localmente com docker-compose.yml

# Segurança (ALTERE EM PRODUÇÃO!)
JWT_SECRET=local-jwt-secret-change-me
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=local-refresh-secret-change-me

# AWS / S3 (opcional para desenvolvimento local)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Firebase (opcional para notificações push)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Pagamentos (opcional para testar checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_GATEWAY_PROVIDER=stripe

# Seed do admin
ADMIN_EMAIL=admin@lavagemdomicilio.com.br
ADMIN_PASSWORD=Admin@123

