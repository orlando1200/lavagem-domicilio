// CLIENT & VEHICLES
// ========================================

model ClientProfile {
  userId                 String   @id @map("user_id") @db.Uuid
  defaultPaymentMethodId String?  @map("default_payment_method_id") @db.Uuid
  averageRating          Decimal? @map("average_rating") @db.Decimal(3, 2)
  totalOrders            Int      @default(0) @map("total_orders")
  cancellationRate       Decimal  @default(0) @map("cancellation_rate") @db.Decimal(5, 2)
  loyaltyPoints          Int      @default(0) @map("loyalty_points")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

enum VehicleCategory {
  moto



































































  expired
}

enum DriverOnboardingStatus {
  pending_documents
  awaiting_kit
  active
  rejected
  completed
}

model DriverProfile {
  userId                       String             @id @map("user_id") @db.Uuid
  displayName                  String             @map("display_name") @db.VarChar(120)
  status                       DriverStatus       @default(draft)
  onboardingStatus             DriverOnboardingStatus @default(pending_documents) @map("onboarding_status")
  serviceRadiusKm              Decimal            @map("service_radius_km") @db.Decimal(6, 2)
  currentZoneId                String?            @map("current_zone_id") @db.Uuid
  averageRating                Decimal?           @map("average_rating") @db.Decimal(3, 2)
  totalCompletedOrders         Int                @default(0) @map("total_completed_orders")




















































































































































































































// SERVICE CATALOG
// ========================================

model ServiceCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(120)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.Text
  icon        String?   @db.VarChar(80)
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")

  services Service[]

  @@map("service_categories")
}

enum ServiceMode {
  main
















































































// COVERAGE ZONES
// ========================================

model CoverageZone {
  id             String    @id @default(uuid()) @db.Uuid
  city           String    @db.VarChar(120)
  state          String    @db.Char(2)
  name           String    @db.VarChar(120)
  slug           String    @unique @db.VarChar(120)
  neighborhoods  String[]  @default([]) @map("neighborhoods")
  surgeEnabled   Boolean   @default(false) @map("surge_enabled")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  pricingRules   ZonePricingRule[]
  serviceRegions ServiceRegion[]
  drivers        DriverProfile[]
  orders         Order[]

  @@map("coverage_zones")
}

model ZonePricingRule {
  id                   String    @id @default(uuid()) @db.Uuid
























































































































  platformFee           Decimal       @map("platform_fee") @db.Decimal(12, 2)
  driverPayoutAmount    Decimal       @map("driver_payout_amount") @db.Decimal(12, 2)
  totalAmount           Decimal       @map("total_amount") @db.Decimal(12, 2)
  paymentStatus         PaymentStatus @default(pending) @map("payment_status")
  paymentMethod         PaymentMethod @map("payment_method")
  source                String?       @map("source") @db.VarChar(30)
  isRecurring           Boolean       @default(false) @map("is_recurring")
  customerNotes         String?       @map("customer_notes") @db.Text
  internalNotes         String?       @map("internal_notes") @db.Text
  pricingSnapshot       Json          @map("pricing_snapshot")
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz

















































































































































































































































































































































































































































  referral
}

model Promotion {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @db.VarChar(120)
  promotionType PromotionType @map("promotion_type")
  config        Json
  startsAt      DateTime      @map("starts_at") @db.Timestamptz
  endsAt        DateTime      @map("ends_at") @db.Timestamptz
  isActive      Boolean       @default(true) @map("is_active")

  @@map("promotions")
}

// ========================================
// LOYALTY
// ========================================

enum LoyaltyRewardType {
  discount
  cashback
  free_service
}

enum LoyaltyCampaignStatus {
  draft
  active
  paused
  finished
}

model LoyaltyCampaign {
  id          String                @id @default(uuid()) @db.Uuid
  name        String                @db.VarChar(120)
  description String?               @db.Text
  rewardType  LoyaltyRewardType     @map("reward_type")
  pointsCost  Int                   @map("points_cost")
  rewardValue Decimal               @map("reward_value") @db.Decimal(12, 2)
  status      LoyaltyCampaignStatus @default(draft)
  startsAt    DateTime?             @map("starts_at") @db.Timestamptz
  endsAt      DateTime?             @map("ends_at") @db.Timestamptz
  redemptions Int                   @default(0) @map("redemptions")
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  @@map("loyalty_campaigns")
}

